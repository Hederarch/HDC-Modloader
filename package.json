{
  "name": "wish-granter",
  "version": "0.0.1",
  "description": "Modloader for Sleeper Game's Hyperspace Deck Command",
  "main": "dist/exports.js",
  "type": "module",
  "mocha": {
    "enable-source-maps": true,
    "spec": "./dist/**/*_test.js",
    "ui": "qunit",
    "require": "./dist/tests/hooks.js",
    "inline-diffs": true
  },
  "files": [
    "package.json",
    "README.md",
    "src/**/*.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "!src/test/",
    "!src/**/*_test.ts",
    "!dist/test/",
    "!dist/**/*_test.js",
    "!dist/**/*_test.js.map",
    "!dist/**/*_test.d.ts",
    "!dist/**/*_test.d.ts.map"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/exports.d.ts",
        "default": "./dist/exports.js"
      }
    }
  },
  "types": "./dist/exports.ts",
  "scripts": {
    "pretty": "prettier --write src/**/*.ts",
    "lint": "npx eslint src --cache --fix",
    "\n========== Building ==========": "",
    "build": "npm run clean && tsc && node dist/cleaner.js",
    "clean": "shx rm -rf ./dist/*",
    "\n========== Testing ==========": "",
    "test": "npm run build && mocha ",
    "start": "npm run build && electron-forge start --app-path ./dist/index.js",
    "debug": "npm run build && electron-forge start --app-path ./dist/index.js --vscode",
    "\n========== Exporting ==========": "",
    "package": "electron-forge package -- --platform=\"win32,linux\"",
    "make": "electron-forge make -- --platform=\"win32,linux\""
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/claire-aware/WishGranter.git"
  },
  "keywords": [
    "modloader",
    "game"
  ],
  "author": "Claire Woods Flechette.net",
  "license": "CC0-1.0",
  "bugs": {
    "url": "https://github.com/Hederarch/HDC-Modloader/issues"
  },
  "homepage": "https://github.com/Hederarch/HDC-Modloader#readme",
  "dependencies": {
    "steam-locate": "^1.0.6"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.0",
    "@types/sinon": "^21.0.0",
    "electron": "41.0.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "mocha": "^11.7.5",
    "prettier": "^3.8.1",
    "shx": "^0.4.0",
    "sinon": "^21.0.3",
    "source-map-support": "^0.5.21",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "lint-staged": {
    "*.{ts}": "eslint --cache --fix",
    "*.{ts,js,css,md}": "prettier --write"
  }
}
