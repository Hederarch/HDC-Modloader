{
  "configurations": [
    {
      "name": "Mocha",
      "type": "node",
      "request": "launch",
      "preLaunchTask": "npm: build",
      "runtimeArgs": [
        "${workspaceRoot}/node_modules/.bin/mocha",
        "--inspect-brk",
      ],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
    },
    {
        "command": "npm run debug",
        "name": "Electron Main",
        "request": "launch",
        "type": "node-terminal"
    },
  ]
}